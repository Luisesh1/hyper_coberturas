{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "dist-codex-check/",
    "dist-temp/",
    "dist.precheck-root-owned/",
    "dist.precheck-root-owned.premerge-root-owned/",
    "build-verify/"
  ],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "error"
  },
  "globals": {
    "React": "readonly",
    "JSX": "readonly"
  }
}
