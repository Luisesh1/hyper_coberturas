# ============================================================
# HYPERLIQUID TRADING BOT — Variables del servidor
# ============================================================
# Copiar como .env y rellenar con valores reales.
#
#   cp server/.env.example server/.env
#
# Ver DEPLOYMENT.md para instrucciones completas.
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ── Hyperliquid API ──────────────────────────────────────────
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# ── Uniswap RPCs (enriquecimiento de pools) ─────────────────
UNI_RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
UNI_RPC_ARBITRUM=https://arbitrum-one-rpc.publicnode.com
UNI_RPC_OPTIMISM=https://optimism-rpc.publicnode.com
UNI_RPC_BASE=https://base-rpc.publicnode.com
UNI_RPC_POLYGON=https://polygon-bor-rpc.publicnode.com
UNI_SCAN_TIMEOUT_MS=20000

# ── Telegram (consultas entrantes) ───────────────────────────
TELEGRAM_POLL_INTERVAL_MS=3000
TELEGRAM_CONFIG_REFRESH_INTERVAL_MS=60000
TELEGRAM_LONG_POLL_TIMEOUT_SEC=20

# ── Defaults de trading ─────────────────────────────────────
DEFAULT_LEVERAGE=10
MARGIN_MODE=cross             # cross | isolated

# ── CORS ─────────────────────────────────────────────────────
# En Docker Compose esta variable se inyecta automaticamente.
# Solo necesaria si corres el servidor fuera de Docker.
# Desarrollo sin docker: CLIENT_URL=*
# Produccion: NUNCA usar *, definir URL concreta.
CLIENT_URL=http://localhost:5174

# ── Seguridad (OBLIGATORIO en produccion) ────────────────────
# Generar valores unicos y seguros con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# En desarrollo se usan valores por defecto (inseguros).
# En produccion el servidor NO arrancara sin valores seguros.
JWT_SECRET=
SETTINGS_ENCRYPTION_KEY=

# ── Base de datos ────────────────────────────────────────────
# En Docker Compose esta variable se inyecta automaticamente.
# Solo necesaria si corres el servidor fuera de Docker.
# DATABASE_URL=postgresql://testbot:password@localhost:5432/testbot

# ── SSL de base de datos (solo produccion) ───────────────────
# Si tu PostgreSQL requiere SSL, se activa automaticamente en produccion.
# Para desactivar la verificacion estricta del certificado:
# DB_SSL_REJECT_UNAUTHORIZED=false

# ── Bootstrap dev (solo para npm run seed:dev) ───────────────
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123
DEV_ADMIN_NAME=Administrador
