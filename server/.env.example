# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ── Hyperliquid API ───────────────────────────────────────────────────────────
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# ── Defaults de trading ───────────────────────────────────────────────────────
DEFAULT_ASSET=BTC
DEFAULT_LEVERAGE=10
MARGIN_MODE=cross             # cross | isolated

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5174

# ── JWT ───────────────────────────────────────────────────────────────────────
# Usar un secreto largo y aleatorio en producción:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production

# ── Base de datos ─────────────────────────────────────────────────────────────
# En Docker Compose esta variable se inyecta automáticamente.
# Solo necesaria si corres el servidor fuera de Docker.
# DATABASE_URL=postgresql://testbot:testbot_pass@localhost:5432/testbot
