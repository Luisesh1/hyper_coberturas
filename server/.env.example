# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production

# ── Hyperliquid API ───────────────────────────────────────────────────────────
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# ── Uniswap RPCs (enriquecimiento de pools) ──────────────────────────────────
UNI_RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
UNI_RPC_ARBITRUM=https://arbitrum-one-rpc.publicnode.com
UNI_RPC_OPTIMISM=https://optimism-rpc.publicnode.com
UNI_RPC_BASE=https://base-rpc.publicnode.com
UNI_RPC_POLYGON=https://polygon-bor-rpc.publicnode.com
UNI_SCAN_TIMEOUT_MS=20000

# ── Defaults de trading ───────────────────────────────────────────────────────
DEFAULT_LEVERAGE=10
MARGIN_MODE=cross             # cross | isolated

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5174

# ── JWT ───────────────────────────────────────────────────────────────────────
# Usar un secreto largo y aleatorio en producción:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-in-production
SETTINGS_ENCRYPTION_KEY=change-me-too

# ── Base de datos ─────────────────────────────────────────────────────────────
# En Docker Compose esta variable se inyecta automáticamente.
# Solo necesaria si corres el servidor fuera de Docker.
# DATABASE_URL=postgresql://testbot:testbot_pass@localhost:5432/testbot

# ── Bootstrap dev ──────────────────────────────────────────────────────────────
# Solo usado por `npm run seed:dev`
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123
DEV_ADMIN_NAME=Administrador
