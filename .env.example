# ============================================================
# HYPERLIQUID TRADING BOT - Environment Variables
# ============================================================
# Copia este archivo como .env y rellena tus valores reales

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- Hyperliquid API ---
# URL base de la API REST
HL_API_URL=https://api.hyperliquid.xyz
# URL del WebSocket de Hyperliquid
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# --- Wallet / Cuenta ---
# Clave privada de la wallet (con 0x al inicio)
PRIVATE_KEY=0xyour_private_key_here
# Direccion publica de la wallet
WALLET_ADDRESS=0xyour_wallet_address_here

# --- Configuracion del Bot ---
# Apalancamiento por defecto (1-100)
DEFAULT_LEVERAGE=10
# Modo de margen: cross o isolated
MARGIN_MODE=cross

# --- CORS (Frontend) ---
# Dev local sin docker: CLIENT_URL=* (permite cualquier origen)
# Dev con docker:       CLIENT_URL=http://localhost  (nginx en puerto 80)
# Produccion:          CLIENT_URL=https://tudominio.com
CLIENT_URL=*

# --- Seguridad ---
# Secret para firmar tokens JWT (opcional, para auth futura)
JWT_SECRET=your_jwt_secret_here
SETTINGS_ENCRYPTION_KEY=your_settings_encryption_key_here
