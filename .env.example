# ============================================================
# HYPERLIQUID TRADING BOT — Variables de entorno (raiz)
# ============================================================
# Este archivo contiene variables usadas por docker-compose.
# Copiar como .env y rellenar con valores reales.
#
#   cp .env.example .env
#
# Ver DEPLOYMENT.md para instrucciones completas.
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────────
POSTGRES_DB=testbot
POSTGRES_USER=testbot
# OBLIGATORIO: password seguro para la base de datos
# Generar con: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Produccion (ignorado en desarrollo) ──────────────────────
# URL del frontend para validacion CORS.
# Desarrollo: se inyecta automaticamente como http://localhost:5174
# Produccion: definir con la URL real (NUNCA usar *)
# CLIENT_URL=http://tu-servidor-ip

# Puerto externo de nginx en produccion (default: 80)
# NGINX_PORT=80
